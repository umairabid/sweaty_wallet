<div id="transaction-rules-page" class="p-2">
  <div class="block items-center justify-between p-4">
    <div class="w-full">
      <div class="mb-4">
        <h1 class="text-xl font-semibold text-gray-900 sm:text-2xl">Your Rules</h1>
      </div>
      <div class="sm:flex">
        <div class="ml-auto flex items-center space-x-2 sm:space-x-3">
          <a class="flex p-2 py-1.5 rounded-lg text-sm text-white bg-primary-700 items-center justify-center" data-turbo-stream href="<%= new_transaction_rule_path() %>">
            <div class="flex items-center gap-x-3"><%= render 'icons/plus' %> Add Rule </div>
          </a>
        </div>
      </div>
    </div>
  </div>
  <div class="relative overflow-x-auto p-4 pt-0">
    <% if @transaction_rules.empty? %>
      <div class="bg-white border border-gray-200 rounded-lg p-4 text-sm text-gray-600">
        <p class="font-semibold text-gray-800 mb-1">How rules work</p>
        <p>Rules let you automatically categorize transactions as they're imported. Each rule defines one or more conditions — like a keyword in the description or a merchant name — and assigns a category when those conditions are met.</p>
        <p class="mt-2">After importing transactions, you can preview any rule to see which transactions it matches and apply the category in bulk.</p>
        <a class="mt-3 inline-flex items-center gap-x-2 p-2 py-1.5 rounded-lg text-sm text-white bg-primary-700" data-turbo-stream href="<%= new_transaction_rule_path %>">
          <%= render 'icons/plus' %> Add your first rule
        </a>
      </div>
    <% else %>
      <div class="border border-gray-300 rounded-lg overflow-hidden">
        <table class="w-full text-sm text-left rtl:text-right text-gray-500">
          <thead class="text-xs text-gray-700 uppercase bg-gray-50">
            <tr>
              <th scope="col" class="p-4 border-blue-gray-100 bg-primary-700">
                <p class="block font-sans text-sm antialiased font-normal leading-none text-white">Name</p>
              </th>
              <th scope="col" class="p-4 border-blue-gray-100 bg-primary-700">
                <p class="block font-sans text-sm antialiased font-normal leading-none text-white">Target Category</p>
              </th>
              <th scope="col" class="p-4 border-blue-gray-100 bg-primary-700"></th>
            </tr>
          </thead>
          <tbody>
            <% @transaction_rules.each do |rule| %>
              <tr class="bg-white border-b">
                <td class="p-4 py-2">
                  <%= rule.name %>
                </td>
                <td class="p-4 py-2">
                  <%= rule.category.name %>
                </td>
                <td class="p-4 py-2">
                  <div class="flex">
                    <%= link_to('Manage',
                    edit_transaction_rule_path(id: rule.id),
                    class: 'flex p-2 py-1.5 rounded-lg text-sm text-white bg-blue-700 items-center justify-center mx-2') %>
                    <%= link_to('Preview',
                    preview_transaction_rule_path(id: rule.id),
                    class: 'flex p-2 py-1.5 rounded-lg text-sm text-white bg-green-700 items-center justify-center mx-2') %>
                    <%= link_to('Delete',
                    transaction_rule_path(id: rule.id),
                    data: {turbo_method: :delete, turbo_confirm: 'Are you sure?'},
                    class: 'flex p-2 py-1.5 rounded-lg text-sm text-white bg-red-700 items-center justify-center mx-2') %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>
  </div>
</div>
